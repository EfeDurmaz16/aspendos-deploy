{
    "name": "aspendos",
    "private": true,
    "packageManager": "bun@1.1.30",
    "workspaces": [
        "apps/web",
        "services/api",
        "packages/*"
    ],
    "scripts": {
        "postinstall": "ln -sf ../@biomejs/biome/bin/biome node_modules/.bin/biome 2>/dev/null; ln -sf ../turbo/bin/turbo node_modules/.bin/turbo 2>/dev/null; true",
        "dev": "turbo run dev --filter=@aspendos/web --filter=@aspendos/api",
        "dev:all": "turbo run dev",
        "dev:web": "turbo run dev --filter=@aspendos/web",
        "dev:api": "turbo run dev --filter=@aspendos/api",
        "build": "turbo run build",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check .",
        "check:fix": "biome check --write .",
        "bench:web-dev": "bash scripts/benchmark_web_dev.sh",
        "release:ready": "bash ./scripts/check_release_readiness.sh",
        "prepare": "husky"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.11",
        "husky": "^9.1.0",
        "lint-staged": "^15.2.0",
        "turbo": "^2.4.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,json}": [
            "biome check --write --no-errors-on-unmatched"
        ]
    },
    "dependencies": {},
    "overrides": {
        "ai": "^6.0.49",
        "lucide-react": "^0.562.0"
    }
}
