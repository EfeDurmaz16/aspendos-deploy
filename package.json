{
    "name": "aspendos",
    "private": true,
    "packageManager": "bun@1.3.4",
    "workspaces": [
        "apps/web",
        "services/api",
        "services/eval",
        "packages/*"
    ],
    "scripts": {
        "postinstall": "ln -sf ../@biomejs/biome/bin/biome node_modules/.bin/biome 2>/dev/null; ln -sf ../turbo/bin/turbo node_modules/.bin/turbo 2>/dev/null; true",
        "dev": "turbo run dev --filter=@aspendos/web --filter=@aspendos/api",
        "dev:all": "turbo run dev",
        "dev:web": "turbo run dev --filter=@aspendos/web",
        "dev:api": "turbo run dev --filter=@aspendos/api",
        "build": "turbo run build",
        "build:api": "bun run --cwd services/api build",
        "build:web": "bun run --cwd apps/web build",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check .",
        "check:fix": "biome check --write .",
        "typecheck:web": "bun run --cwd apps/web typecheck",
        "typecheck:api": "bunx tsc -p services/api/tsconfig.typecheck.json --noEmit",
        "test:core": "bunx vitest run packages/aspendos-core/src/**/*.test.ts",
        "test:api": "bun run --cwd services/api test",
        "test:web": "bun run --cwd apps/web test",
        "convex:typecheck": "bunx convex typecheck",
        "bench:web-dev": "bash scripts/benchmark_web_dev.sh",
        "brand:generate": "bun run scripts/generate-brand-assets.ts",
        "generated:check": "bash scripts/check_generated_artifacts.sh",
        "toolchain:check": "bash scripts/check_toolchain.sh",
        "release:ready": "bash ./scripts/check_release_readiness.sh",
        "prepare": "husky"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.11",
        "husky": "^9.1.0",
        "lint-staged": "^15.2.0",
        "png-to-ico": "^3.0.1",
        "sharp": "^0.34.5",
        "stripe": "^22.0.1",
        "typescript": "^5.9.3",
        "turbo": "^2.4.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,json}": [
            "biome format --write --no-errors-on-unmatched"
        ]
    },
    "dependencies": {
        "@convex-dev/workflow": "^0.3.9",
        "@fides/sdk": "workspace:*",
        "convex": "^1.35.1"
    },
    "overrides": {
        "ai": "^6.0.49",
        "lucide-react": "^0.562.0"
    }
}
