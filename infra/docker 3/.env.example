# Docker Compose environment — copy to .env

# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# WorkOS
WORKOS_CLIENT_ID=client_...
WORKOS_API_KEY=sk_test_...
WORKOS_COOKIE_PASSWORD=minimum-32-characters-here-please
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# AI
AI_GATEWAY_API_KEY=

# Memory
SUPERMEMORY_API_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# BYOK
BYOK_ENCRYPTION_SECRET=minimum-32-characters

# Sandbox
DAYTONA_API_KEY=
E2B_API_KEY=

# Browser
STEEL_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=

# Messaging (optional)
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
WHATSAPP_TOKEN=
