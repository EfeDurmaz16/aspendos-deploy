# YULA OS — Environment Variables
# Copy to .env.local and fill in values

# ─── Convex (Phase A) ───
NEXT_PUBLIC_CONVEX_URL="https://your-project.convex.cloud"
CONVEX_DEPLOY_KEY=""

# ─── WorkOS AuthKit (Phase A) ───
WORKOS_CLIENT_ID="client_..."
WORKOS_API_KEY="sk_test_..."
WORKOS_COOKIE_PASSWORD=""  # min 32 chars: openssl rand -base64 24
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/callback"

# ─── AI — Vercel AI Gateway ───
AI_GATEWAY_API_KEY=""

# ─── Memory — SuperMemory ───
SUPERMEMORY_API_KEY=""

# ─── Stripe Billing (Phase B) ───
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── BYOK Vault Encryption ───
BYOK_ENCRYPTION_SECRET=""  # min 32 chars

# ─── Sandbox — Daytona (primary) ───
DAYTONA_API_KEY=""

# ─── Sandbox — E2B (fallback) ───
E2B_API_KEY=""

# ─── Browser — Steel.dev ───
STEEL_API_KEY=""

# ─── Anthropic (Computer Use) ───
ANTHROPIC_API_KEY=""

# ─── Analytics — PostHog ───
NEXT_PUBLIC_POSTHOG_KEY=""
POSTHOG_API_KEY=""

# ─── Rate Limiting — Upstash Redis ───
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Messaging (optional, env-gated) ───
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""
TELEGRAM_BOT_TOKEN=""
DISCORD_BOT_TOKEN=""
WHATSAPP_TOKEN=""

# ─── Service URLs ───
NEXT_PUBLIC_API_URL="http://localhost:8787"
FRONTEND_URL="http://localhost:3000"
