        "@aspendos/shared-types": "workspace:*",
        "@chat-adapter/discord": "^4.20.2",
        "@chat-adapter/slack": "^4.20.2",
        "@chat-adapter/state-pg": "^4.20.2",
        "@chat-adapter/telegram": "^4.20.2",
        "@chat-adapter/whatsapp": "^4.20.2",
        "@google/genai": "^1.37.0",
        "@hono/node-server": "^1.13.7",
        "@sentry/node": "^10.38.0",
        "@supermemory/tools": "^1.4.0",
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.36.2",
        "ai": "^6.0.49",
        "ajv": "^8.18.0",
        "chat": "^4.20.2",
        "helmet": "^8.1.0",
        "hono": "^4.6.0",
        "nanoid": "^5.1.6",
        "openai": "^6.16.0",
        "resend": "^6.9.2",
        "supermemory": "^3.0.0",
        "zod": "^3.24.0"
