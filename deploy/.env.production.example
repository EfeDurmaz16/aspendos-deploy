# Yula OS - Production Environment Variables
# Fill these values in the deployment environment. Do not commit real values.

# ============================================
# Convex
# ============================================
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=
CONVEX_SERVICE_SECRET=

# ============================================
# Database
# ============================================
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ============================================
# WorkOS AuthKit
# ============================================
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://yula.dev/callback

# ============================================
# FIDES / governance
# ============================================
AGIT_REPO_PATH=
FIDES_TEST_SIGNING_SECRET=

# ============================================
# Billing - Stripe
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# Messaging approvals
# ============================================
BOT_APPROVAL_WEBHOOK_SECRET=
AGENT_RESUME_URL=

# ============================================
# AI and memory
# ============================================
AI_GATEWAY_API_KEY=
SUPERMEMORY_API_KEY=

# ============================================
# BYOK and sandbox providers
# ============================================
BYOK_ENCRYPTION_SECRET=
DAYTONA_API_KEY=
E2B_API_KEY=
STEEL_API_KEY=
ANTHROPIC_API_KEY=

# ============================================
# Messaging providers
# ============================================
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
WHATSAPP_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ============================================
# Ops, URLs, and security
# ============================================
NODE_ENV=production
PORT=8080
NEXT_PUBLIC_APP_URL=https://yula.dev
NEXT_PUBLIC_API_URL=https://api.yula.dev
FRONTEND_URL=https://yula.dev
CORS_ORIGINS=https://yula.dev
CRON_SECRET=
ADMIN_USER_IDS=
ADMIN_EMAILS=
METRICS_BEARER_TOKEN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
